{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "description": "TTICKETT — rode sempre npm run dev (Express + Vite). Não use apenas vite.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "dev:3000": "cmd.exe /c dev-3000.cmd",
