# Google OAuth Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase Credentials
# Frontend (Vite) - visíveis no bundle do navegador
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend (Express) - NUNCA expor no frontend
# Recomendado para rotas server-side (ex.: upload storage sem depender de políticas públicas)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Server (Express)
PORT=3000
