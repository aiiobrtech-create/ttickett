# Google OAuth Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase Credentials
# Frontend (Vite) - visíveis no bundle do navegador
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Se o front for servido de outro domínio que o Express, URL do backend (sem barra no final). Ex.: https://api.seudominio.com
# VITE_API_BASE=

# Backend (Express) - NUNCA expor no frontend
# Recomendado para rotas server-side (ex.: upload storage sem depender de políticas públicas)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Server (Express)
PORT=3000
# Origens para CORS (só se usar VITE_API_BASE com host diferente). Ex.: https://app.seudominio.com ou *
# CORS_ORIGINS=
# Na VPS, defina 0.0.0.0 para aceitar conexões atrás do Nginx/reverse proxy
# LISTEN_HOST=0.0.0.0

# E-mail — tickets por empresa (webhook inbound + Resend para respostas)
# Gere um segredo forte e envie no header x-ttickett-email-secret ou Authorization: Bearer <segredo>
EMAIL_WEBHOOK_SECRET=
# https://resend.com — domínio remetente deve estar verificado
RESEND_API_KEY=
# Remetente verificado no Resend (recomendado em produção). Se definido, Reply-To será o supportEmail da empresa.
EMAIL_FROM=
